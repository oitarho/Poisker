## Poisker local dev (Docker Compose)

# Backend (exposed)
BACKEND_PORT=8000

# Postgres
POSTGRES_DB=poisker
POSTGRES_USER=poisker
POSTGRES_PASSWORD=poisker
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=xyz

# Admin token for moderation endpoints (optional)
POISKER_ADMIN_TOKEN=dev-admin-token
