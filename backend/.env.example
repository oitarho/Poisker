 # Runtime
 POISKER_ENV=local
 POISKER_LOG_LEVEL=INFO
 POISKER_API_V1_PREFIX=/api/v1
 
 # CORS (comma-separated)
 POISKER_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080
 
 # Security / JWT
 POISKER_JWT_ISSUER=poisker
 POISKER_JWT_AUDIENCE=poisker
 POISKER_JWT_ACCESS_TTL_SECONDS=900
 POISKER_JWT_REFRESH_TTL_SECONDS=1209600
 # Generate a strong secret for production
 POISKER_JWT_SECRET=dev-change-me
 
 # Database
 POISKER_DATABASE_URL=postgresql+asyncpg://poisker:poisker@localhost:5432/poisker
 POISKER_DB_ECHO=0
 
 # Redis
 POISKER_REDIS_URL=redis://localhost:6379/0
 
 # Typesense
 POISKER_TYPESENSE_HOST=localhost
 POISKER_TYPESENSE_PORT=8108
 POISKER_TYPESENSE_PROTOCOL=http
 POISKER_TYPESENSE_API_KEY=xyz
POISKER_TYPESENSE_LISTINGS_COLLECTION=poisker_listings

# Media uploads (local dev)
POISKER_MEDIA_DIR=var/media
POISKER_MEDIA_PUBLIC_BASE=/media
POISKER_UPLOAD_MAX_BYTES=5242880
# Comma-separated if you override; default allows jpeg/png/webp
# POISKER_UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Admin/moderation (local dev)
# Set this to enable admin endpoints.
POISKER_ADMIN_TOKEN=dev-admin-token

# SMTP (Yandex example). Set POISKER_SMTP_ENABLED=1 to send real mail.
POISKER_SMTP_ENABLED=0
POISKER_SMTP_HOST=smtp.yandex.ru
POISKER_SMTP_PORT=465
POISKER_SMTP_USERNAME=
POISKER_SMTP_PASSWORD=
POISKER_SMTP_FROM_EMAIL=noreply@example.com
POISKER_SMTP_FROM_NAME=Poisker
POISKER_SMTP_USE_TLS=1

# Email verification / password reset codes (Redis)
# POISKER_CODE_PEPPER=optional-extra-secret
POISKER_CODE_TTL_SECONDS=600
POISKER_CODE_RESEND_COOLDOWN_SECONDS=60
POISKER_CODE_MAX_SENDS_PER_HOUR=5
POISKER_CODE_MAX_FAILED_ATTEMPTS=5
